---
import '../styles/global.css';
import Header from '../components/header.astro';
import Footer from '../components/footer.astro';
---

<html lang="en">
  <head>
    <title>Teaching — Arnav Gupta</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body class="min-h-screen">
    <Header />
    <main class="max-w-5xl mx-auto px-4 py-10">
      <h1 class="text-3xl font-bold">Teaching</h1>
      <p class="mt-4 text-gray-600">Courses, workshops, and teaching materials.</p>
      <section class="mt-6 grid gap-4">
        <article class="rounded-lg border p-4 bg-white/5">
          <h2 class="font-semibold">Course or Workshop Title</h2>
          <p class="text-gray-300 mt-2">Short description.</p>
        </article>
      </section>
    </main>
    <Footer />
  </body>
</html>
