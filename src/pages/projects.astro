---
import '../styles/global.css';
import Header from '../components/header.astro';
import Footer from '../components/footer.astro';
import projects from '../data/projects.json';
---

<html lang="en">
  <head>
    <title>Projects — Arnav Gupta</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body class="min-h-screen">
    <Header />
    <main class="max-w-5xl mx-auto px-4 py-10">
      <h1 class="text-3xl font-bold">Projects</h1>
      <p class="mt-4 text-gray-600">A curated gallery of projects — click a card to view a case study.</p>

      <section class="mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((p) => (
          <a href={`/projects/${p.slug}`} class="group block rounded-lg border border-white/10 overflow-hidden bg-white/5 hover:scale-[1.01] transition-transform">
            <div class="h-40 w-full bg-gray-900 flex items-center justify-center">
              <img src={p.cover} alt={p.title} class="object-cover h-full w-full" />
            </div>
            <div class="p-4">
              <div class="text-sm text-gray-300">{p.category}</div>
              <h3 class="mt-1 font-semibold">{p.title}</h3>
              <p class="mt-2 text-sm text-gray-400">{p.summary}</p>
            </div>
          </a>
        ))}
      </section>
    </main>
    <Footer />
  </body>
</html>
