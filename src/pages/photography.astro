---
import '../styles/global.css';
import Header from '../components/header.astro';
import Footer from '../components/footer.astro';
---

<html lang="en">
  <head>
    <title>Photography — Arnav Gupta</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body class="min-h-screen">
    <Header />
    <main class="max-w-5xl mx-auto px-4 py-10">
      <h1 class="text-3xl font-bold">Photography</h1>
      <p class="mt-4 text-gray-600">Gallery coming soon — placeholder page.</p>
      <section class="mt-6 grid grid-cols-2 sm:grid-cols-3 gap-4">
        <div class="bg-white/5 h-40 rounded" />
        <div class="bg-white/5 h-40 rounded" />
        <div class="bg-white/5 h-40 rounded" />
      </section>
    </main>
    <Footer />
  </body>
</html>
