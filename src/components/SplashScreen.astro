<section id="splash-screen" class="splash-screen" aria-hidden="false">
  <div class="splash-content">
    <div class="splash-header">
      <pre class="splash-logo">Arnav Gupta Portfolio</pre>
    </div>
    <div id="splash-lines" class="splash-lines" aria-live="polite"></div>
    <div id="splash-progress" class="splash-progress"></div>
  </div>

  <script is:inline>
    (() => {
      const splash = document.getElementById('splash-screen');
      const linesEl = document.getElementById('splash-lines');
      const progressEl = document.getElementById('splash-progress');
      if (!splash || !linesEl || !progressEl) return;

      const bootLines = [
        'Initializing portfolio boot sequence...',
        'Authenticating vault...',
        'Loading experience matrix...',
        'Mapping research archives...',
        'Spawning project nodes...',
        'Syncing teaching modules...',
        'Optimizing hacker aesthetic...',
        'Starting interface...',
      ];

      const randomText = () => {
        const chars = '0101ABCDEF<>/\\|{}[]!@#$%^&*';
        return Array.from({ length: 40 }, () => chars[Math.floor(Math.random() * chars.length)]).join('');
      };

      const wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms));
      const addLine = (text, cls = '') => {
        const line = document.createElement('div');
        line.className = `splash-line ${cls}`.trim();
        line.textContent = text;
        linesEl.appendChild(line);
        linesEl.scrollTop = linesEl.scrollHeight;
        return line;
      };

      const fillProgress = async (label, duration = 800) => {
        const row = document.createElement('div');
        row.className = 'splash-progress-row';
        row.innerHTML = `
          <span class="splash-progress-label">${label}</span>
          <span class="splash-progress-value" id="${label.replace(/\s+/g, '-')}-value">0%</span>
          <div class="splash-progress-bar"><div class="splash-progress-fill" id="${label.replace(/\s+/g, '-')}-fill"></div></div>
        `;
        progressEl.appendChild(row);

        const fill = row.querySelector('.splash-progress-fill');
        const value = row.querySelector('.splash-progress-value');
        if (!fill || !value) return;

        const start = performance.now();
        return new Promise((resolve) => {
          const animate = (now) => {
            const elapsed = now - start;
            const pct = Math.min(100, Math.round((elapsed / duration) * 100));
            fill.style.width = `${pct}%`;
            value.textContent = `${pct}%`;
            if (pct < 100) {
              requestAnimationFrame(animate);
            } else {
              resolve();
            }
          };
          requestAnimationFrame(animate);
        });
      };

      const run = async () => {
        for (const text of bootLines) {
          addLine(`> ${text}`);
          await wait(200 + Math.random() * 120);
        }

        addLine('> Boot splash sequence loaded.', 'accent');
        await wait(200);

        const steps = [
          { label: 'Encrypting memory cache', duration: 620 },
          { label: 'Compiling green text engine', duration: 720 },
          { label: 'Mounting portfolio pages', duration: 780 },
        ];

        for (const step of steps) {
          await fillProgress(step.label, step.duration);
          await wait(100);
        }

        addLine('> SYSTEM READY — loading interface...', 'accent');
        await wait(500);
        splash.classList.add('splash-hidden');
        setTimeout(() => {
          splash.remove();
        }, 300);
      };

      const shuffle = () => {
        const block = document.createElement('div');
        block.className = 'splash-shuffle';
        block.textContent = randomText();
        linesEl.appendChild(block);
        linesEl.scrollTop = linesEl.scrollHeight;
        if (linesEl.children.length > 22) {
          linesEl.removeChild(linesEl.firstChild);
        }
      };

      const interval = setInterval(shuffle, 180);
      run().then(() => clearInterval(interval));
    })();
  </script>
</section>
