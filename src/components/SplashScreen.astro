<section id="splash-screen" class="splash-screen" aria-hidden="false">
  <div class="splash-content">
    <div class="splash-header">
      <div class="splash-title">Arnav Gupta</div>
      <div class="splash-subtitle">Loading portfolio environment</div>
    </div>
    <div id="splash-lines" class="splash-lines" aria-live="polite"></div>
    <div id="splash-progress" class="splash-progress"></div>
  </div>

  <script is:inline>
    (() => {
      const splash = document.getElementById('splash-screen');
      const linesEl = document.getElementById('splash-lines');
      const progressEl = document.getElementById('splash-progress');
      if (!splash || !linesEl || !progressEl) return;

      const bootLines = [
        'Initialising secure session...',
        'Loading content modules...',
        'Synchronizing research assets...',
        'Applying visual theme...',
        'Verifying project metadata...',
        'Optimizing page rendering...',
      ];

      const wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms));
      const addLine = (text, cls = '') => {
        const line = document.createElement('div');
        line.className = `splash-line ${cls}`.trim();
        line.textContent = text;
        linesEl.appendChild(line);
        linesEl.scrollTop = linesEl.scrollHeight;
        return line;
      };

      const fillProgress = async (label, duration = 700) => {
        const row = document.createElement('div');
        row.className = 'splash-progress-row';
        row.innerHTML = `
          <div class="splash-progress-header">
            <span class="splash-progress-label">${label}</span>
            <span class="splash-progress-value" id="${label.replace(/\s+/g, '-')}-value">0%</span>
          </div>
          <div class="splash-progress-bar"><div class="splash-progress-fill" id="${label.replace(/\s+/g, '-')}-fill"></div></div>
        `;
        progressEl.appendChild(row);

        const fill = row.querySelector('.splash-progress-fill');
        const value = row.querySelector('.splash-progress-value');
        if (!fill || !value) return;

        const start = performance.now();
        return new Promise((resolve) => {
          const animate = (now) => {
            const elapsed = now - start;
            const pct = Math.min(100, Math.round((elapsed / duration) * 100));
            fill.style.width = `${pct}%`;
            value.textContent = `${pct}%`;
            if (pct < 100) {
              requestAnimationFrame(animate);
            } else {
              resolve();
            }
          };
          requestAnimationFrame(animate);
        });
      };

      const run = async () => {
        addLine('> BOOT SEQUENCE STARTED', 'accent');
        await wait(120);

        for (const text of bootLines) {
          addLine(`> ${text}`);
          await wait(220);
        }

        const steps = [
          { label: 'Engine initialization', duration: 600 },
          { label: 'Asset loading', duration: 750 },
          { label: 'Interface launch', duration: 650 },
        ];

        for (const step of steps) {
          await fillProgress(step.label, step.duration);
          await wait(120);
        }

        addLine('> PORTFOLIO READY', 'accent');
        await wait(340);

        splash.classList.add('splash-hidden');
        setTimeout(() => splash.remove(), 300);
      };

      run();
    })();
  </script>
</section>
