<section id="splash-screen" class="splash-screen" aria-hidden="false">
  <div class="splash-terminal-window">
    <div class="splash-terminal-titlebar">
      <div class="terminal-dot red"></div>
      <div class="terminal-dot amber"></div>
      <div class="terminal-dot green"></div>
      <div class="terminal-title">portfolio-boot</div>
    </div>

    <div id="splash-lines" class="splash-lines" aria-live="polite"></div>

    <div class="splash-progress-bar-shell">
      <div class="splash-progress-status" id="splash-progress-status">Starting boot...</div>
      <div class="splash-progress-track">
        <div class="splash-progress-fill" id="splash-progress-fill"></div>
      </div>
      <div class="splash-progress-value" id="splash-progress-label">0%</div>
    </div>
  </div>

  <script is:inline>
    (() => {
      const splash = document.getElementById('splash-screen');
      const linesEl = document.getElementById('splash-lines');
      const fillEl = document.getElementById('splash-progress-fill');
      const statusEl = document.getElementById('splash-progress-status');
      const labelEl = document.getElementById('splash-progress-label');
      if (!splash || !linesEl || !fillEl || !statusEl || !labelEl) return;

      const bootLines = [
        '> booting portfolio kernel...',
        '> mounting experience modules...',
        '> loading interface assets...',
        '> initializing terminal output...',
      ];

      const statusMessages = [
        'system diagnostics',
        'content streams',
        'finalizing boot',
      ];

      const wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms));
      const addLine = (text, cls = '') => {
        const line = document.createElement('div');
        line.className = `splash-line ${cls}`.trim();
        line.textContent = text;
        linesEl.appendChild(line);
        linesEl.scrollTop = linesEl.scrollHeight;
        return line;
      };

      const progress = async (target, duration) => {
        const start = performance.now();
        return new Promise((resolve) => {
          const animate = (now) => {
            const elapsed = now - start;
            const pct = Math.min(100, Math.round((elapsed / duration) * 100));
            fillEl.style.width = `${pct}%`;
            labelEl.textContent = `${pct}%`;
            if (pct < target) {
              requestAnimationFrame(animate);
            } else {
              resolve();
            }
          };
          requestAnimationFrame(animate);
        });
      };

      const finish = () => {
        splash.classList.add('splash-hidden');
        setTimeout(() => splash.remove(), 160);
      };

      const skip = () => {
        finish();
      };

      document.addEventListener('keydown', skip, { once: true });
      document.addEventListener('click', skip, { once: true });
      document.addEventListener('touchstart', skip, { once: true });

      const run = async () => {
        for (const text of bootLines) {
          addLine(text);
          await wait(60);
        }

        for (let i = 0; i < statusMessages.length; i += 1) {
          statusEl.textContent = `loading ${statusMessages[i]}...`;
          const target = Math.round(((i + 1) / statusMessages.length) * 100);
          await progress(target, 160);
        }

        statusEl.textContent = 'boot complete';
        await progress(100, 100);
        await wait(80);
        finish();
      };

      run();
    })();
  </script>
</section>
