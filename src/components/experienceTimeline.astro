---
const experiences = [
  {
    title: 'Machine Learning Research Assistant',
    dates: 'May 2025 - Present',
    org: 'Duke University Applied Machine Learning Lab',
    bullets: [
      'Working on EEG-based brain-computer interface (BCI) systems, specifically P300 spellers.',
      'Implemented deep learning and classical ML approaches including EEGNet and SWLDA.',
      'Built preprocessing pipelines for EEG data and visualization tools.'
    ]
  },
  {
    title: 'Software Engineer',
    dates: 'Jul 2024 - Present',
    org: 'Big Fin Scientific',
    bullets: [
      'Built Android-based data collection system DCS LinkStream 2.0.',
      'Integrated multiple hardware sensors into a unified pipeline.'
    ]
  },
  {
    title: 'Machine Learning Intern',
    dates: 'Mar 2023 - Jul 2024',
    org: '4th Vector Technologies',
    bullets: ['Developed computer vision pipelines for industrial defect detection.']
  }
];
---

<section class="mt-8 rounded-2xl border border-white/20 bg-black/40 p-6 sm:p-8 font-mono text-white">
  <h2 class="text-2xl font-bold">Experience — Timeline</h2>

  <div class="mt-6 relative">
    <div class="absolute left-3 top-0 bottom-0 w-0.5 bg-white/10 hidden sm:block"></div>

    <ol class="space-y-8">
      {experiences.map((e, i) => (
        <li class="relative pl-8 sm:pl-12">
          <div class="absolute left-0 top-2 h-3 w-3 rounded-full bg-sky-500 ring-4 ring-black"></div>
          <div class="flex items-center justify-between gap-4">
            <div>
              <h3 class="font-semibold">{e.title}</h3>
              <div class="text-sm text-gray-300">{e.org}</div>
            </div>
            <div class="text-sm text-gray-400">{e.dates}</div>
          </div>

          <ul class="mt-3 list-disc pl-5 text-gray-200">
            {e.bullets.map((b) => (
              <li>{b}</li>
            ))}
          </ul>
        </li>
      ))}
    </ol>
  </div>
</section>
