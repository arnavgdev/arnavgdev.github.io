---
import { Icon } from 'astro-icon/components';
---

<header class="sticky top-0 z-50 bg-black text-white font-mono shadow-md">
  <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between gap-4">

    <!-- Clickable name linking to home page -->
    <a href="/" class="text-xl font-mono font-bold transition">
      Arnav Gupta
    </a>

    <div class="flex flex-wrap items-center justify-end gap-3">
      <nav class="whitespace-nowrap text-sm sm:text-base font-semibold text-gray-200">
        <a href="#about" class="header-nav-link">About</a>
        <span class="mx-2 text-gray-500">|</span>
        <a href="#experience" class="header-nav-link">Experience</a>
        <span class="mx-2 text-gray-500">|</span>
        <a href="#research" class="header-nav-link">Research</a>
        <span class="mx-2 text-gray-500">|</span>
        <a href="#projects" class="header-nav-link">Projects</a>
        <span class="mx-2 text-gray-500">|</span>
        <a href="#academic" class="header-nav-link">Academic</a>
        <span class="mx-2 text-gray-500">|</span>
        <a href="#contact" class="header-nav-link">Contact</a>
      </nav>

      <nav class="flex items-center gap-2">
        <a
          href="https://www.linkedin.com/in/arnav-gupta-09884a22b"
          target="_blank"
          rel="noopener"
          class="header-icon-button"
          aria-label="LinkedIn"
          title="LinkedIn"
        >
          <Icon name="mdi:linkedin" class="w-5 h-5" />
        </a>

        <a
          href="https://github.com/arnav-gupta-123"
          target="_blank"
          rel="noopener"
          class="header-icon-button"
          aria-label="GitHub"
          title="GitHub"
        >
          <Icon name="mdi:github" class="w-5 h-5" />
        </a>

        <a
          href="mailto:arnavg363@gmail.com"
          class="header-icon-button"
          aria-label="Email"
          title="Email"
        >
          <Icon name="mdi:email-outline" class="w-5 h-5" />
        </a>

        <a
          href="/resume.pdf"
          target="_blank"
          rel="noopener"
          class="header-icon-button"
          aria-label="Resume"
          title="Resume"
        >
          <Icon name="mdi:file-document-outline" class="w-5 h-5" />
        </a>

        <button
          id="themeToggleButton"
          type="button"
          class="header-icon-button"
          aria-label="Toggle color theme"
          title="Toggle color theme"
        >
          <Icon name="mdi:theme-light-dark" class="w-5 h-5" />
        </button>
      </nav>
    </div>
  </div>

  <script is:inline>
    (() => {
      const button = document.getElementById('themeToggleButton');

      if (!(button instanceof HTMLButtonElement)) return;

      const updateLabel = () => {
        const currentTheme = window.siteTheme?.getTheme?.() ?? 'dark';
        const action = currentTheme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode';
        button.setAttribute('aria-label', action);
        button.setAttribute('title', action);
      };

      button.addEventListener('click', () => {
        window.siteTheme?.toggleTheme?.();
      });

      window.addEventListener('theme:change', updateLabel);
      updateLabel();
    })();
  </script>
</header>
