---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import siteLogo from '../assets/site-logo.png';
---

<header class="sticky top-0 z-50 bg-black text-white font-mono shadow-md">
  <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between gap-4">

    <!-- Clickable name linking to home page -->
    <a href="/" class="text-xl font-mono font-bold transition flex items-center gap-3">
      <!-- Logo container forced to a small, centered circle -->
      <span class="w-8 h-8 flex-shrink-0 inline-flex items-center justify-center rounded-full overflow-hidden bg-white/10" aria-hidden="true">
        <Image src={siteLogo} alt="site logo" class="w-full h-full object-cover" />
      </span>
      <span class="leading-none">Arnav Gupta</span>
    </a>

    <!-- Compact hamburger and theme toggle on the right -->
    <div class="flex items-center gap-3">
      <button id="themeToggleButton" type="button" class="header-icon-button theme-toggle-button" aria-label="Toggle color theme" title="Toggle color theme">
        <span class="theme-icon theme-icon-system"><Icon name="mdi:theme-light-dark" class="w-5 h-5" /></span>
        <span class="theme-icon theme-icon-light hidden"><Icon name="mdi:weather-sunny" class="w-5 h-5" /></span>
        <span class="theme-icon theme-icon-dark hidden"><Icon name="mdi:weather-night" class="w-5 h-5" /></span>
      </button>
      <button id="navToggleButton" class="header-icon-button" aria-label="Open menu" title="Menu">
        <Icon name="mdi:menu" class="w-5 h-5" />
      </button>
    </div>
  </div>

  <!-- Slide-out drawer -->
  <div id="navDrawerOverlay" class="hidden fixed inset-0 z-40 bg-black/40" aria-hidden="true"></div>
  <aside id="navDrawer" class="fixed right-0 top-0 z-50 h-full w-80 max-w-[90vw] transform translate-x-full bg-black text-white shadow-2xl transition-transform duration-300">
    <div class="p-6">
      <div class="flex items-center justify-between">
        <a href="/" class="text-lg font-bold">Arnav Gupta</a>
        <button id="navCloseButton" class="header-icon-button" aria-label="Close menu" title="Close">
          <Icon name="mdi:close" class="w-5 h-5" />
        </button>
      </div>

      <nav class="mt-6 flex flex-col gap-3 text-lg">
        <a href="/" class="header-nav-link">About</a>
        <a href="/experience" class="header-nav-link">Experience</a>
        <a href="/projects" class="header-nav-link">Projects</a>
        <a href="/teaching" class="header-nav-link">Teaching</a>
        <a href="/research" class="header-nav-link">Research</a>
        <a href="/contact" class="header-nav-link">Contact</a>
      </nav>

    </div>
  </aside>

  <script is:inline>
    (() => {
      const openDrawer = () => {
        document.getElementById('navDrawer')?.classList.remove('translate-x-full');
        document.getElementById('navDrawerOverlay')?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      };

      const closeDrawer = () => {
        document.getElementById('navDrawer')?.classList.add('translate-x-full');
        document.getElementById('navDrawerOverlay')?.classList.add('hidden');
        document.body.style.overflow = '';
      };

      const toggleButton = document.getElementById('navToggleButton');
      const closeButton = document.getElementById('navCloseButton');
      const overlay = document.getElementById('navDrawerOverlay');

      toggleButton?.addEventListener('click', openDrawer);
      closeButton?.addEventListener('click', closeDrawer);
      overlay?.addEventListener('click', closeDrawer);

      const storageKey = 'theme-preference';
      const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
      const root = document.documentElement;
      const systemIcon = document.querySelector('.theme-icon-system');
      const lightIcon = document.querySelector('.theme-icon-light');
      const darkIcon = document.querySelector('.theme-icon-dark');
      const themeButton = document.getElementById('themeToggleButton');

      const getStoredPreference = () => localStorage.getItem(storageKey);
      const getSystemTheme = () => (mediaQuery.matches ? 'dark' : 'light');
      const resolveTheme = () => {
        const stored = getStoredPreference();
        return stored === 'light' || stored === 'dark' ? stored : getSystemTheme();
      };

      const applyTheme = (theme) => {
        root.classList.remove('theme-light', 'theme-dark');
        root.classList.add(`theme-${theme}`);
        root.dataset.theme = theme;
      };

      const setToggleState = (preference) => {
        if (systemIcon) systemIcon.classList.toggle('hidden', preference !== 'system');
        if (lightIcon) lightIcon.classList.toggle('hidden', preference !== 'light');
        if (darkIcon) darkIcon.classList.toggle('hidden', preference !== 'dark');

        const label = preference === 'system'
          ? 'System theme'
          : preference === 'light'
            ? 'Light theme'
            : 'Dark theme';

        if (themeButton) {
          themeButton.setAttribute('aria-label', label);
          themeButton.setAttribute('title', label);
        }
      };

      const setPreference = (preference) => {
        if (preference === 'light' || preference === 'dark') {
          localStorage.setItem(storageKey, preference);
        } else {
          localStorage.removeItem(storageKey);
        }
        applyTheme(resolveTheme());
        setToggleState(preference);
        window.dispatchEvent(new CustomEvent('theme:change', { detail: { theme: root.dataset.theme } }));
      };

      const onSystemThemeChange = () => {
        if (!getStoredPreference()) {
          applyTheme(resolveTheme());
          setToggleState('system');
          window.dispatchEvent(new CustomEvent('theme:change', { detail: { theme: root.dataset.theme } }));
        }
      };

      if (typeof mediaQuery.addEventListener === 'function') {
        mediaQuery.addEventListener('change', onSystemThemeChange);
      } else if (typeof mediaQuery.addListener === 'function') {
        mediaQuery.addListener(onSystemThemeChange);
      }

      const themeOrder = ['system', 'light', 'dark'];
      const getNextPreference = () => {
        const current = window.siteTheme?.getPreference?.() ?? 'system';
        const nextIndex = (themeOrder.indexOf(current) + 1) % themeOrder.length;
        return themeOrder[nextIndex];
      };

      if (!window.siteTheme) {
        window.siteTheme = {
          getTheme: () => root.dataset.theme || resolveTheme(),
          getPreference: () => getStoredPreference() ?? 'system',
          setPreference,
          toggleTheme: () => setPreference(getNextPreference()),
        };
      }

      applyTheme(resolveTheme());
      setToggleState(window.siteTheme?.getPreference?.() ?? 'system');

      if (themeButton instanceof HTMLElement) {
        themeButton.addEventListener('click', () => {
          const next = getNextPreference();
          window.siteTheme?.setPreference?.(next);
        });
      }
    })();
  </script>
</header>